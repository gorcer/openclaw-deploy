# OpenClaw .env пример
# Скопируй в директорию деплоя и заполни своими данными

# ─── Обязательные ───
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
MINIMAX_API_KEY=your_minimax_api_key_here
OWNER_TELEGRAM_ID=141455495

# ─── Опциональные ───
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# ─── Конфигурация ───
OPENCLAW_VERSION=latest
DATA_DIR=/opt/openclaw/data
CLIENT_DATA_DIR=/opt/openclaw/client_data
CLIENT_VOLUME_SIZE=100G
PORT=18789
